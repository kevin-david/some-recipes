{
  "name": "some-recipes",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch & wrangler pages dev dist --port 8788",
    "build": "vite build",
    "deploy": "npm run check && vite build && wrangler pages deploy dist --branch master",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "typecheck": "tsgo --noEmit",
    "check": "npm run fmt:check && npm run lint && npm run typecheck"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "bootstrap": "^5.3.0",
    "hono": "^4.6.0",
    "jose": "^5.9.0",
    "react": "^18.3.0",
    "react-bootstrap": "^2.10.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript/native-preview": "^7.0.0-dev.20260414.1",
    "@vitejs/plugin-react": "^4.3.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wrangler": "^4.82.2"
  }
}
